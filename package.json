{
  "name": "coil",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "COIL — tap-to-fling mobile game built with TypeScript + Vite",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:cg": "tsc --noEmit && vite build --base=./ --outDir dist-cg",
    "preview": "vite preview",
    "preview:cg": "vite preview --outDir dist-cg",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-tests.cjs"
  },
  "devDependencies": {
    "esbuild": "^0.21.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
